# Configuration email (Gmail)
# 1. Dans Gmail: Paramètres > Comptes > Sécurité
# 2. Activez la validation en 2 étapes
# 3. Créez un "Mot de passe d'application" pour le portfolio
# 4. Copiez ce fichier en .env et renseignez les valeurs

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=gracemahouk@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application
DEFAULT_FROM_EMAIL=gracemahouk@gmail.com
CONTACT_RECIPIENT_EMAIL=gracemahouk@gmail.com
